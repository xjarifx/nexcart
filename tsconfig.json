{
  "exclude": ["prisma.config.ts", "prisma/seed.ts", "src/tests"],
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",
    "rootDir": ".",
    "outDir": "./dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "nodenext",
    "paths": {
      "prisma/config": ["./node_modules/prisma/config.js"]
    }
  }
}
